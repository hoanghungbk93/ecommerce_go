                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 6
